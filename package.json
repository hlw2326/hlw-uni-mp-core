{
    "name": "@hlw-uni/mp-core",
    "version": "1.0.34",
    "description": "UniApp 运行时核心包 — composables、Pinia stores、工具函数、UI 组件",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "publish:npm": "pnpm build && npm publish --access public"
    },
    "peerDependencies": {
        "pinia": ">=2.1.0",
        "vue": ">=3.4.0"
    },
    "devDependencies": {
        "@dcloudio/types": "^3.4.30",
        "@types/md5": "^2.3.6",
        "@types/node": "^20.19.39",
        "pinia": "^2.3.1",
        "typescript": "^4.9.5",
        "vite": "5.2.8",
        "vite-plugin-dts": "^4.5.4"
    },
    "dependencies": {
        "md5": "^2.3.0"
    }
}
